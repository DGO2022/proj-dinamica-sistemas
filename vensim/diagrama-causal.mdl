{UTF-8}
Stock en Gondola  = A FUNCTION OF( Generacion de mermados,Translado a gondola,Ventas)\
		 ~~|
Stock en Gondola= INTEG (Translado a gondola - Generacion de mermados - Ventas,
		150)
	~	Cajas
	~	Stock disponible para venta en gondola
	|

Demanda diaria  = A FUNCTION OF( )
	~	
	~		|

Descarg de Camion  = A FUNCTION OF( "Capacidad Max. trastienda",Inventario en Trastienda\
		,Frecuencia de llegada de camiones)
	~	
	~		|

Descarte de Basura  = A FUNCTION OF( Productos Mermados)
	~	
	~		|

Inventario en Trastienda  = A FUNCTION OF( Descarg de Camion,Translado a gondola) ~~|
Inventario en Trastienda= INTEG (Descarga del camion - Translado a gondola,
		400)
	~	Cajas
	~	Stock almacenado en trastienda
	|

Ventas  = A FUNCTION OF( Demanda diaria,Stock en Gondola)
	~	
	~		|

Translado a gondola  = A FUNCTION OF( Inventario en Trastienda,Ritmo de reposición)
	~	
	~		|

Generacion de mermados  = A FUNCTION OF( Velocidad de deterioro,Stock en Gondola) ~~|
Generacion de mermados=Stock en Gondola * Tasa de generacion de mermas
	~	Cajas/Day
	~	Mermas generadas por deterioro o caducidad
	|

Velocidad de deterioro  = A FUNCTION OF( )
	~	
	~		|

Productos Mermados  = A FUNCTION OF( Descarte de Basura,Generacion de mermados)
	~	
	~		|

"Capacidad Max. trastienda"=800
	~	Cajas [200,2000,50]
	~	Capacidad maxima de almacenamiento en trastienda
	|

Faltante Stock=MAX (0, Nivel Objetivo Gondola - Stock en Gondola)
	~	Cajas
	~	Diferencia entre objetivo y stock actual en gondola
	|

Nivel Objetivo Gondola=200
	~	Cajas [50,500,10]
	~	Nivel de stock objetivo que se desea mantener en gondola
	|

Faltante Trastienda=MAX (0, Nivel Objetivo Trastienda - Inventario en Trastienda)
	~	Cajas
	~	Diferencia entre objetivo y stock actual de la trastienda
	|

Nivel Objetivo Trastienda=500
	~	Cajas [100,800,50]
	~	Stock objetivo que se desea mantener en la trastienda
	|

Frecuencia de llegada de camiones=Faltante Trastienda / Tiempo de retraso del proveedor
	~	Cajas/Day
	~	Cajas que llegan por dia basadas en reponer el faltante
	|

Tiempo de retraso del proveedor=2
	~	Day [1,10,1]
	~	Tiempo de demora en la entrega del proveedor
	|

Ritmo de reposición=IF THEN ELSE (Inventario en Trastienda > 0, SMOOTH (Faltante Stock\
		, 0.5), 0)
	~	Cajas/Day
	~	Velocidad de traslado de trastienda a gondola segun faltante
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 90
	~	Day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Day
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Day [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Day [0,?]
	~	The time step for the simulation.
	|

