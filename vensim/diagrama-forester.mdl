{UTF-8}
"Capacidad Max. trastienda"=800
	~	Cajas [200,2000,50]
	~	Capacidad maxima de almacenamiento en trastienda
	|

Descarga del camion=IF THEN ELSE (Inventario en Trastienda < "Capacidad Max. trastienda"\
		, Tasa de llegada de camion, 0
	)
	~	Cajas/Day
	~	Camion descarga solo si hay espacio en trastienda
	|

Descarte de Basura=Productos Mermados * Tasa de descarte de mermados
	~	Cajas/Day
	~	Se descarta una fraccion de los mermados cada dia
	|

Faltante Stock=MAX (0, Nivel Objetivo Gondola - Stock en Gondola)
	~	Cajas
	~	Diferencia entre objetivo y stock actual en gondola
	|

Generacion de mermados=Stock en Gondola * Tasa de generacion de mermas
	~	Cajas/Day
	~	Mermas generadas por deterioro o caducidad
	|

Inventario en Trastienda= INTEG (Descarga del camion - Translado a gondola,
		400)
	~	Cajas
	~	Stock almacenado en trastienda
	|

Nivel Objetivo Gondola=200
	~	Cajas [50,500,10]
	~	Nivel de stock objetivo que se desea mantener en gondola
	|

Productos Mermados= INTEG (Generacion de mermados - Descarte de Basura,
		0)
	~	Cajas
	~	Acumulacion de productos mermados pendientes de descarte
	|

Stock en Gondola= INTEG (Translado a gondola - Generacion de mermados - Ventas,
		150)
	~	Cajas
	~	Stock disponible para venta en gondola
	|

Tasa de descarte de mermados=0.5
	~	1/Day [0.1,1,0.1]
	~	Fraccion de productos mermados que se descarta por dia
	|

Tasa de generacion de mermas=0.005
	~	1/Day [0,0.05,0.005]
	~	Fraccion del stock en gondola que se merma por dia
	|

Faltante Trastienda=MAX (0, Nivel Objetivo Trastienda - Inventario en Trastienda)
	~	Cajas
	~	Diferencia entre objetivo y stock actual de la trastienda
	|

Nivel Objetivo Trastienda=500
	~	Cajas [100,800,50]
	~	Stock objetivo que se desea mantener en la trastienda
	|

Pedidos al proveedor=Faltante Trastienda / Tiempo de retraso del proveedor
	~	Cajas/Day
	~	Tasa de pedido al proveedor basada en el faltante de trastienda
	|

Tasa de llegada de camion=DELAY3 (Pedidos al proveedor, Tiempo de retraso del proveedor\
		)
	~	Cajas/Day
	~	Cajas que llegan con retraso de transito del proveedor
	|

Tiempo de retraso del proveedor=2
	~	Day [1,10,1]
	~	Tiempo de demora en la entrega del proveedor
	|

Tiempo de ajuste de reposicion=1
	~	Day [0.5,5,0.5]
	~	Tiempo de ajuste para convertir faltante en tasa de reposicion
	|

Tasa de Reposición=IF THEN ELSE (Inventario en Trastienda > 0, DELAY1 (Faltante Stock\
		/ Tiempo de ajuste de reposicion, Tiempo de ajuste de reposicion), 0)
	~	Cajas/Day
	~	Velocidad de traslado de trastienda a gondola con retraso de reposicion
	|

Tasa de Ventas Concretadas=15
	~	Cajas/Day [5,100,5]
	~	Ventas diarias con valor constante
	|

Translado a gondola=MIN (Inventario en Trastienda / TIME STEP, Tasa de Reposición)
	~	Cajas/Day
	~	Flujo real de trastienda a gondola limitado por stock disponible
	|

Ventas=MIN (Tasa de Ventas Concretadas, Stock en Gondola / TIME STEP)
	~	Cajas/Day
	~	Ventas limitadas por disponibilidad en gondola
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 90
	~	Day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Day
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Day [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Day [0,?]
	~	The time step for the simulation.
	|

